generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String           @id @default(cuid())
  phone                    String           @unique
  name                     String?
  profileImage             String?
  countryCode              String
  password                 String
  balance                  Float            @default(0.0)
  totalInvestment          Float            @default(0.0)
  totalEarnings            Float            @default(0.0)
  todayEarnings            Float            @default(0.0)
  referralCode             String           @unique
  referredBy               String?
  registrationBonusClaimed Boolean          @default(false)
  lastCheckIn              DateTime?
  lastWithdrawal           DateTime?
  checkInCount             Int              @default(0)
  role                     String           @default("USER")
  lastSeen                 DateTime?
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt
  investments              Investment[]
  notifications            Notification[]
  transactions             Transaction[]
  supportMessages          SupportMessage[]

  @@map("usersdata")
}

model SupportMessage {
  id        String   @id @default(cuid())
  userId    String
  message   String
  fromAdmin Boolean  @default(false)
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Product {
  id          String       @id @default(cuid())
  code        String       @unique
  name        String
  image       String
  price       Float
  dailyIncome Float
  cycleIncome Float
  status      String       @default("Available")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  investments Investment[]
}

model Investment {
  id             String   @id @default(cuid())
  userId         String
  productId      String
  amount         Float
  startDate      DateTime @default(now())
  endDate        DateTime
  lastEarningsAt DateTime @default(now())
  nextEarningsAt DateTime
  status         String   @default("Active")
  autoReinvest   Boolean  @default(false)
  cycleCount     Int      @default(0)
  product        Product  @relation(fields: [productId], references: [id])
  user           User     @relation(fields: [userId], references: [id])
}

model Transaction {
  id        String   @id @default(cuid())
  userId    String
  type      String
  amount    Float
  status    String   @default("PENDING")
  reference String?
  notes     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  message   String
  type      String   @default("IN_APP")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model Verification {
  id        String   @id @default(cuid())
  phone     String   @unique
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}
